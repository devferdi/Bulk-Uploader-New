SHOPIFY_CLIENT_ID=your_partner_app_client_id
SHOPIFY_CLIENT_SECRET=your_partner_app_client_secret
SHOPIFY_APP_URL=https://shopify-bulk-oauth.youragency.com
SHOPIFY_REDIRECT_URI=https://shopify-bulk-oauth.youragency.com/auth/callback
SHOPIFY_APP_SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_files,write_files,read_metaobjects,write_metaobjects,read_metaobject_definitions
SHOPIFY_API_VERSION=2026-01
AGENCY_API_KEY=choose-a-long-random-secret
OAUTH_DB_PATH=/absolute/path/to/shopify_oauth.db
